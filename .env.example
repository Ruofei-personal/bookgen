# --- 后端（可复制为 backend/.env，在 backend/ 下运行 uv run …）---
# 书籍根目录：默认未设置时使用 <仓库根>/content/books
# CONTENT_ROOT=/absolute/path/to/content/books
# CORS_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# --- 前端（可复制为 frontend/.env.local）---
# 服务端组件请求 API 的基地址（无尾部斜杠）
API_URL=http://127.0.0.1:8001
# 若将来有客户端直连 API 的组件，可配置：
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8001

# --- scripts/check.sh（部署后健康检查，可在 shell 中 export）---
# FRONTEND_URL=http://127.0.0.1:8765
# CHECK_MAX_ATTEMPTS=30
# CHECK_INTERVAL_SEC=2
